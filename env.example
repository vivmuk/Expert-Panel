# Required — get yours at https://venice.ai (rotate any key that was ever committed!)
VENICE_API_KEY=

# Where the SQLite engagement database lives.
# Local dev: ./data (default). Railway: attach a volume at /data and set this to /data.
DATA_DIR=./data

# Optional tuning
# DEFAULT_PANEL_SIZE=20
# MAX_PANEL_SIZE=100
# PANEL_CONCURRENCY=8
# COST_CIRCUIT_BREAKER_MULTIPLIER=3.0
